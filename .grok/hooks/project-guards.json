{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|search_replace|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "block-generated-writes.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "warn-stray-gradle.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
