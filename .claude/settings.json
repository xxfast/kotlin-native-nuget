{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-generated-writes.sh\"",
            "statusMessage": "Checking write target"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/warn-stray-gradle.sh\"",
            "statusMessage": "Checking for stray Gradle builds"
          }
        ]
      }
    ]
  }
}
